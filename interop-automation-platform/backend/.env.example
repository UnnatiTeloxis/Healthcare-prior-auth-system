# Inferno Validator Service URL
INFERNO_VALIDATOR_URL=http://fhir-validator-wrapper:4567

# Default Implementation Guides to load on startup (comma-separated)
# Format: package-id#version
DEFAULT_IGS=hl7.fhir.us.core#6.1.0,hl7.fhir.us.davinci-pas#2.0.1,hl7.fhir.us.davinci-crd#2.0.1,hl7.fhir.us.davinci-dtr#2.0.1,hl7.fhir.us.carin-bb#2.0.0

# CORS allowed origins (comma-separated)
CORS_ORIGINS=http://localhost,http://localhost:80,http://frontend
