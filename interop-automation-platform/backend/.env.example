# Copy to .env when running the backend outside Docker (from backend/).
# Start Inferno first: docker compose up -d fhir-validator-wrapper
INFERNO_VALIDATOR_URL=http://127.0.0.1:4567
DATABASE_URL=postgresql://interop:interop123@localhost:5433/interop
REDIS_URL=redis://localhost:6380
# Store IG .tgz packages on D: to avoid filling the system drive (~158 US R4 packages).
FHIR_PACKAGES_PATH=D:/fhir_packages
FHIR_VALIDATOR_HTML_PATH=../frontend/public/fhir-validator.html
DEFAULT_IGS=hl7.fhir.us.core#6.1.0
# Install every local curated IG into Inferno on backend startup (background).
# First boot can take 30–60+ minutes; selecting an IG afterward is much faster.
PRELOAD_ALL_LOCAL_IGS=true
# Prefer posting local .tgz packages to Inferno (best for a local validator).
PREFER_LOCAL_IG_UPLOAD=true
INFERNO_DISABLE_TX=false
CORS_ORIGINS=*

# Hosted mode (no docker validator needed; dev/testing only — no PHI, no SLA):
# INFERNO_VALIDATOR_URL=https://inferno.healthit.gov/validatorapi
# PRELOAD_ALL_LOCAL_IGS=false
# PREFER_LOCAL_IG_UPLOAD=false
