# =============================================================================
# Database
# =============================================================================
DATABASE_URL=postgresql://interop:interop123@postgres:5432/interop
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20
POSTGRES_USER=interop
POSTGRES_PASSWORD=interop123
POSTGRES_DB=interop

# =============================================================================
# Redis
# =============================================================================
REDIS_URL=redis://redis:6379
REDIS_CACHE_TTL=3600

# =============================================================================
# API
# =============================================================================
API_HOST=0.0.0.0
API_PORT=8000
API_DEBUG=true
API_RELOAD=true

# =============================================================================
# FHIR Server
# =============================================================================
FHIR_SERVER_URL=http://localhost:8080
FHIR_SERVER_TIMEOUT=30
FHIR_SERVER_RETRIES=3
# Terminology / Validator
# Results are passed through unchanged from the Inferno/HL7 validator wrapper.
# Use the same settings as inferno.healthit.gov/validator for parity:
#   TX_SERVER_URL=https://tx.fhir.org/r4
#   DISPLAY_ISSUES_ARE_WARNINGS=true
# Do NOT set DISABLE_TX (its presence — even "false" — disables terminology validation).
# Local terminology packages under backend/fhir_packages/ keep ValueSet checks fast.
# Inferno FHIR validator wrapper (docker-compose service name from inside backend container)
INFERNO_VALIDATOR_URL=http://fhir-validator-wrapper:4567
FHIR_PACKAGES_PATH=/app/fhir_packages
FHIR_TEST_CASES_PATH=/app/test-cases
DEFAULT_IGS=hl7.fhir.us.core#9.0.0,hl7.fhir.us.davinci-crd#2.2.1,hl7.fhir.us.davinci-dtr#2.2.0,hl7.fhir.us.davinci-pas#2.2.1
# Match docker-compose Inferno defaults for offline / parity (override for hosted TX):
DISABLE_TX=true
DISPLAY_ISSUES_ARE_WARNINGS=false
CORS_ORIGINS=*
TERMINOLOGY_SERVER_URL=https://tx.fhir.org/r4
TERMINOLOGY_SERVER_TIMEOUT=30
TERMINOLOGY_CACHE_TTL=86400

# =============================================================================
# CQL Engine
# =============================================================================
CQL_CACHE_ENABLED=true
CQL_CACHE_TTL=3600
CQL_EXECUTION_TIMEOUT=60

# =============================================================================
# Authentication
# =============================================================================
AUTH_SECRET_KEY=change-me-to-a-long-random-secret-in-production
AUTH_ALGORITHM=HS256
AUTH_ACCESS_TOKEN_EXPIRE_MINUTES=1440
# Optional aliases (same meaning as AUTH_*):
# JWT_SECRET_KEY=...
# JWT_ALGORITHM=HS256
# JWT_EXPIRE_MINUTES=1440

# Optional Google OAuth
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# Frontend (CORS / redirects)
FRONTEND_URL=http://localhost:3000

# Optional: point DATABASE_URL at a host Postgres from Docker Desktop:
# DATABASE_URL=postgresql://USER:PASSWORD@host.docker.internal:5432/YOUR_DB

# =============================================================================
# Data Paths (inside backend container)
# =============================================================================
PROFILES_PATH=/app/data/profiles
QUESTIONNAIRES_PATH=/app/data/questionnaires
CQL_LIBRARIES_PATH=/app/data/cql_libraries
VALUE_SETS_PATH=/app/data/value_sets
CRD_SCENARIOS_PATH=/app/data/scenarios/crd
VALIDATION_RULES_PATH=/app/data/validation_rules

# =============================================================================
# Logging
# =============================================================================
LOG_LEVEL=INFO
LOG_FORMAT=json

# =============================================================================
# Frontend
# =============================================================================
FRONTEND_PORT=3000
VITE_API_BASE_URL=/api

# =============================================================================
# Rate Limiting
# =============================================================================
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_PERIOD=60
