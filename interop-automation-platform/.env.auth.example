# Copy to `.env` in this folder and set YOUR_PASSWORD.
# Used by docker compose / local uvicorn (env_file).

# --- Option A: Docker internal Postgres (default stack) ---
# DATABASE_URL=postgresql://interop:interop123@postgres:5432/interop

# --- Option B: Your fhir_validator_db1 ---
# From Docker backend container (LAN IP / host DB):
DATABASE_URL=postgresql://postgres:gaurav7693@192.168.1.251:5432/fhir_validator_db1
# Alternatives:
# DATABASE_URL=postgresql://postgres:gaurav7693@host.docker.internal:5432/fhir_validator_db1
# DATABASE_URL=postgresql://postgres:gaurav7693@localhost:5432/fhir_validator_db1

DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20

# Auth / JWT (24h = 1440 minutes)
JWT_SECRET_KEY=change-me-to-a-long-random-secret-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440
# Or AUTH_* aliases:
# AUTH_SECRET_KEY=change-me-to-a-long-random-secret-in-production
# AUTH_ALGORITHM=HS256
# AUTH_ACCESS_TOKEN_EXPIRE_MINUTES=1440

FRONTEND_URL=http://localhost:3000
CORS_ORIGINS=*

# Optional Google OAuth (leave empty to hide Google buttons in UI)
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# Keep Inferno / FHIR settings from docker-compose when running in Compose.
INFERNO_VALIDATOR_URL=http://fhir-validator-wrapper:4567
FHIR_PACKAGES_PATH=/app/fhir_packages
